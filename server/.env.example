# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
# Get one free at https://www.mongodb.com/cloud/atlas -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/crowdfunding?retryWrites=true&w=majority

# JWT
# Any long random string, e.g. generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth (Google Identity Services)
# Get one free at https://console.cloud.google.com/apis/credentials -> Create Credentials -> OAuth client ID -> Web application
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Stripe (test mode)
# Get free test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# imgBB (for image upload challenge)
# Get a free key at https://api.imgbb.com/
IMGBB_API_KEY=your-imgbb-api-key
