# Base URL of the server API (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID (same value as the server's GOOGLE_CLIENT_ID)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Stripe publishable (test) key
# https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# imgBB API key, for uploading profile pictures and campaign cover images
# https://api.imgbb.com/
VITE_IMGBB_API_KEY=your-imgbb-api-key
